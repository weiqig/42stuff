#include <stdio.h>
#include <unistd.h>

void	ft_putstr(char *str);

void	putchar(char c)
{
	write(1, &c, 1);
}

void	ft_putstr(char *str)
{
	int	idx;

	idx = 0;
	if (str == '')
	while (str[idx] != '\0')
	{
		write(1, &str[idx], 1);
		idx++;
	}
}

